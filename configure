#!/bin/sh

set -e

usage() {
    echo "Usage: ./configure [options]"
    echo "  --with-debug    enable debug mode (-g3)"
    echo "  --with-clang    compile with clang"
    echo "  --prefix=DIR    set install directory"
    echo "  --help          show this help"
}

debug=0
clang=0
prefix=

for arg in "$@"; do
    case "$arg" in
        --with-debug) debug=1 ;;
        --with-clang) clang=1 ;;
        --prefix=*)   prefix="${arg#*=}" ;;
        --help)       usage; exit 0 ;;
        *)            echo "Unknown option: $arg"; usage; exit 1 ;;
    esac
done

> makefile.rules
if [ "$debug" = 1 ]; then echo "CFLAGS+=-g3"  >> makefile.rules; fi
if [ "$clang" = 1 ]; then echo "CC=clang"      >> makefile.rules; fi
if [ -n "$prefix" ];    then echo "PREFIX=$prefix"    >> makefile.rules; fi
